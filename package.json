    "express-rate-limit": "^8.5.2",
    "lucide-react": "^0.511.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.60.0",
    "pm2": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
